{
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install",
  "outputDirectory": "build/client",
  "framework": null,
  "functions": {
    "api/index.js": {
      "includeFiles": "build/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/api/index"
    }
  ]
}
